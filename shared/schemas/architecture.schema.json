{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://systemcraft.local/schemas/architecture.schema.json",
  "title": "SystemCraft Architecture Graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "description",
    "version",
    "user_idea",
    "assumptions",
    "task_profile",
    "nodes",
    "edges"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "user_idea": { "type": "string", "minLength": 1 },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "task_profile": { "$ref": "#/definitions/taskProfile" },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/architectureNode" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/definitions/architectureEdge" }
    },
    "naive_baseline": { "$ref": "#/definitions/naiveBaseline" }
  },
  "definitions": {
    "nodeType": {
      "type": "string",
      "enum": [
        "input",
        "prompt",
        "llm",
        "knowledge_base",
        "retrieval",
        "tool",
        "memory",
        "human_review",
        "evaluator",
        "output",
        "transform",
        "router",
        "classifier",
        "privacy_filter",
        "fallback",
        "logger"
      ]
    },
    "edgeType": {
      "type": "string",
      "enum": ["data_flow", "control_flow", "review_flow", "fallback_flow"]
    },
    "riskLevel": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "estimateLevel": {
      "type": "string",
      "enum": ["none", "low", "medium", "high"]
    },
    "nodeRiskSeverity": {
      "type": "string",
      "enum": ["warning", "error", "critical"]
    },
    "estimate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relative", "notes"],
      "properties": {
        "relative": { "$ref": "#/definitions/estimateLevel" },
        "notes": { "type": "string", "minLength": 1 },
        "units_per_run": { "type": "number", "minimum": 0 },
        "estimated_seconds": { "type": "number", "minimum": 0 }
      }
    },
    "nodePort": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "sensitive": { "type": "boolean" },
        "format": { "type": "string", "minLength": 1 }
      }
    },
    "nodeRisk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk_type", "severity", "description", "mitigation"],
      "properties": {
        "risk_type": { "type": "string", "minLength": 1 },
        "severity": { "$ref": "#/definitions/nodeRiskSeverity" },
        "description": { "type": "string", "minLength": 1 },
        "mitigation": { "type": "string", "minLength": 1 }
      }
    },
    "nodeAlternative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "tradeoff"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "tradeoff": { "type": "string", "minLength": 1 },
        "when_to_use": { "type": "string", "minLength": 1 }
      }
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "architectureNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "name",
        "description",
        "inputs",
        "outputs",
        "config",
        "risks",
        "cost_estimate",
        "latency_estimate",
        "alternatives",
        "explanation_for_beginner"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "$ref": "#/definitions/nodeType" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/definitions/nodePort" }
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/definitions/nodePort" }
        },
        "config": {
          "type": "object",
          "additionalProperties": true
        },
        "risks": {
          "type": "array",
          "items": { "$ref": "#/definitions/nodeRisk" }
        },
        "cost_estimate": { "$ref": "#/definitions/estimate" },
        "latency_estimate": { "$ref": "#/definitions/estimate" },
        "alternatives": {
          "type": "array",
          "items": { "$ref": "#/definitions/nodeAlternative" }
        },
        "explanation_for_beginner": { "type": "string", "minLength": 1 },
        "position": { "$ref": "#/definitions/position" }
      }
    },
    "architectureEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "target", "kind", "label"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "kind": { "$ref": "#/definitions/edgeType" },
        "label": { "type": "string", "minLength": 1 },
        "data_contract": { "type": "string", "minLength": 1 },
        "condition": { "type": "string", "minLength": 1 }
      }
    },
    "taskProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_type",
        "risk_level",
        "knowledge_intensity",
        "requires_tools",
        "requires_memory",
        "requires_human_review"
      ],
      "properties": {
        "task_type": { "type": "string", "minLength": 1 },
        "risk_level": { "$ref": "#/definitions/riskLevel" },
        "knowledge_intensity": { "$ref": "#/definitions/riskLevel" },
        "requires_tools": { "type": "boolean" },
        "requires_memory": { "type": "boolean" },
        "requires_human_review": { "type": "boolean" },
        "requires_citations": { "type": "boolean" },
        "privacy_sensitivity": { "$ref": "#/definitions/riskLevel" }
      }
    },
    "naiveBaseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "failure_modes"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "failure_modes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
