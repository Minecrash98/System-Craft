# Current optional OpenAI configuration.
# The app works without these values by using deterministic fallbacks.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=12000

# ElevenLabs narration/review configuration.
# Keep real values in .env.local only.
ELEVENLABS_API_KEY=
ELEVENLABS_NARRATOR_VOICE_ID=
ELEVENLABS_BUILDER_VOICE_ID=
ELEVENLABS_REVIEWER_VOICE_ID=
ELEVENLABS_MENTOR_VOICE_ID=
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_DIALOGUE_MODEL=eleven_v3
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_TIMEOUT_MS=120000
